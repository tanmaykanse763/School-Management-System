{
  "name": "school-capm",
  "version": "1.0.0",

  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9"
  },

  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },

  "scripts": {
    "start": "cds watch",

    "watch-schoolui":
      "cds watch --open schoolui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },

  "cds": {

    "requires": {

      "db": {

        "kind": "sqlite"

      }

    }

  },

  "private": true,

  "workspaces": [
    "app/*"
  ]
}