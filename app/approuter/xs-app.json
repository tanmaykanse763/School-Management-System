{
  "welcomeFile": "/schoolui/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/school/(.*)$",
      "target": "/school/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^(.*)$",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa",
      "target": "$1"
    }
  ]
}
