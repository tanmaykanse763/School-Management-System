<mvc:View
    controllerName="schoolui.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    displayBlock="true"
>
    <tnt:ToolPage
        id="toolPage"
        sideExpanded="true"
    >
        <tnt:header>
            <tnt:ToolHeader>
                <Button
                    icon="sap-icon://menu2"
                    type="Transparent"
                    press="onToggleSideNav"
                />

                <core:Icon
                    src="sap-icon://learning-assistant"
                    color="#4f46e5"
                    size="1.4rem"
                    class="sapUiSmallMarginBeginEnd"
                />

                <Title
                    text="EduPortal"
                    level="H5"
                />

                <ToolbarSpacer />

                <HBox alignItems="Center">
                    <SearchField
                        id="globalSearchField"
                        width="250px"
                        search="onSearchApp"
                        placeholder="Search..."
                        class="sapUiTinyMarginEnd"
                    />

                    <!-- Bell Button -->
                    <Button
                        id="notificationButton"
                        icon="sap-icon://bell"
                        type="Transparent"
                        press="onOpenNotifications"
                        tooltip="{= ${notif>/unreadCount} > 0 ? ${notif>/unreadCount} + ' unread' : 'Notifications' }"
                    />
                </HBox>
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation
                id="sideNavigation"
                itemSelect="onNavItemSelect"
            >
                <tnt:NavigationList>
                    <tnt:NavigationListItem
                        key="Dashboard"
                        text="Dashboard"
                        icon="sap-icon://home"
                        visible="{role>/isStudent}" 
                    />
                    <tnt:NavigationListItem
                        key="LeaveRequests"
                        text="Leave Requests"
                        icon="sap-icon://timesheet"
                        visible="{role>/isStudent}"
                    />
                    <tnt:NavigationListItem
                        key="BonafideCert"
                        text="Bonafide Cert."
                        icon="sap-icon://document"
                        visible="{role>/isStudent}"
                    />

                    <tnt:NavigationListItem
                        key="Approval"
                        text="Approval"
                        icon="sap-icon://task"
                        visible="{role>/isAdmin}"
                    />
                </tnt:NavigationList>

                <tnt:fixedItem>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem
                            key="MyProfile"
                            text="My Profile"
                            icon="sap-icon://person-placeholder"
                        />
                        <tnt:NavigationListItem
                            key="Settings"
                            text="Settings"
                            icon="sap-icon://action-settings"
                        />
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <NavContainer id="appNav" />
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
