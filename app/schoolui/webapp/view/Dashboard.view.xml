<mvc:View
    controllerName="schoolui.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="dashboardPage"
        title="Dashboard"
        showNavButton="false"
        backgroundDesign="Transparent">

        <content>

            <ScrollContainer
                height="100%"
                width="100%"
                vertical="true"
                horizontal="false">

                <VBox class="sapUiMediumMargin sapUiMediumMarginTop">

                  
                    <grid:CSSGrid
                        gridTemplateColumns="repeat(4, 1fr)"
                        gridGap="1rem"
                        class="sapUiSmallMarginBottom">

                        
                        <f:Card>

                            <f:content>

                                <VBox class="sapUiMediumMargin">

                                    <core:Icon
                                        src="sap-icon://document"
                                        color="#0f0f0f"
                                        size="1.6rem"
                                        class="sapUiSmallMarginBottom"/>

                                    <Label
                                        text="TOTAL LEAVES"
                                        design="Bold"/>

                                    <Title
                                        text="{student>/totalLeaves}"
                                        level="H5"/>

                                    <Text
                                        text="Applied this year"
                                        class="sapUiTinyMarginTop"/>

                                </VBox>

                            </f:content>

                        </f:Card>

                        <!-- BONAFIDE -->
                        <f:Card>

                            <f:content>

                                <VBox class="sapUiMediumMargin">

                                    <core:Icon
                                        src="sap-icon://document-text"
                                        color="#0f0f0f"
                                        size="1.6rem"
                                        class="sapUiSmallMarginBottom"/>

                                    <Label
                                        text="BONAFIDE ISSUED"
                                        design="Bold"/>

                                    <Title
                                        text="{student>/bonafideIssued}"
                                        level="H5"/>

                                    <Text
                                        text="Certificates issued"
                                        class="sapUiTinyMarginTop"/>

                                </VBox>

                            </f:content>

                        </f:Card>

                        
                        <f:Card>

                            <f:content>

                                <VBox class="sapUiMediumMargin">

                                    <core:Icon
                                        src="sap-icon://pending"
                                        color="#0f0f0f"
                                        size="1.6rem"
                                        class="sapUiSmallMarginBottom"/>

                                    <Label
                                        text="PENDING"
                                        design="Bold"/>

                                    <Title
                                        text="{student>/pending}"
                                        level="H5"/>

                                    <Text
                                        text="Awaiting approval"
                                        class="sapUiTinyMarginTop"/>

                                </VBox>

                            </f:content>

                        </f:Card>

                        
                        <f:Card>

                            <f:content>

                                <VBox class="sapUiMediumMargin">

                                    <core:Icon
                                        src="sap-icon://decline"
                                        color="#0f0f0f"
                                        size="1.6rem"
                                        class="sapUiSmallMarginBottom"/>

                                    <Label
                                        text="REJECTED"
                                        design="Bold"/>

                                    <Title
                                        text="{student>/Rejected}"
                                        level="H5"/>

                                    <Text
                                        text="This semester"
                                        class="sapUiTinyMarginTop"/>

                                </VBox>

                            </f:content>

                        </f:Card>

                    </grid:CSSGrid>

                    
                    <grid:CSSGrid
                        gridTemplateColumns="repeat(4, 1fr)"
                        gridGap="1rem"
                        class="sapUiSmallMarginBottom">

                        
                        <GenericTile
                            press="onOpenLeaveRequest"
                            frameType="TwoByOne"
                            class="sapUiTinyMargin apMGTHdrContent" 
                            width="100%">

                            <TileContent>

                                <VBox
                                    width="100%"
                                    height="100%"
                                    justifyContent="Center"
                                    alignItems="Center"
                                    >

                                    <core:Icon
                                        src="sap-icon://document"
                                        size="2rem"
                                        color="#0f0f0f"
                                        class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>

                                    <Title
                                        text="Apply for Leave"
                                        level="H5"
                                        width="100%"
                                        textAlign="Center"
                                        class="sapUiTinyMarginBottom"/>

                                    <Text
                                        text="Submit a new leave request"
                                        width="100%"
                                        textAlign="Center"/>

                                </VBox>

                            </TileContent>

                        </GenericTile>

                        
                        <GenericTile
                            press="onOpenBonafideDialog"
                            frameType="TwoByOne"
                            class="sapUiTinyMargin apMGTHdrContent"
                            width="100%">

                            <TileContent>

                                <VBox
                                    width="100%"
                                    height="100%"
                                    justifyContent="Center"
                                    alignItems="Center">

                                    <core:Icon
                                        src="sap-icon://document-text"
                                        size="2rem"
                                        color="#0f0f0f"
                                        class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>

                                    <Title
                                        text="Request Bonafide"
                                        level="H5"
                                        width="100%"
                                        textAlign="Center"
                                        class="sapUiTinyMarginBottom"/>

                                    <Text
                                        text="Get an official certificate"
                                        width="100%"
                                        textAlign="Center"/>

                                </VBox>

                            </TileContent>

                        </GenericTile>

                        
                        <GenericTile
                            press="onViewLeaveHistory"
                            frameType="TwoByOne"
                            class="sapUiTinyMargin apMGTHdrContent"
                            width="100%">

                            <TileContent>

                                <VBox
                                    width="100%"
                                    height="100%"
                                    justifyContent="Center"
                                    alignItems="Center">
                                   

                                    <core:Icon
                                        src="sap-icon://history"
                                        size="2rem"
                                        color="#0f0f0f"
                                        class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>

                                    <Title
                                        text="View Leave History"
                                        level="H5"
                                        width="100%"
                                        textAlign="Center"
                                        class="sapUiTinyMarginBottom"/>

                                    <Text
                                        text="Check all leave applications"
                                        width="100%"
                                        textAlign="Center"/>

                                </VBox>

                            </TileContent>

                        </GenericTile>

                        
                        <GenericTile
                            press="onViewRequest"
                            frameType="TwoByOne"
                            class="sapUiTinyMargin apMGTHdrContent"
                            width="100%">

                            <TileContent>

                                <VBox
                                    width="100%"
                                    height="100%"
                                    justifyContent="Center"
                                    alignItems="Center"
                                    >

                                    <core:Icon
                                        src="sap-icon://document"
                                        size="2rem"
                                        color="#0f0f0f"
                                        class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>

                                    <Title
                                        text="View Request"
                                        level="H5"
                                        width="100%"
                                        textAlign="Center"
                                        class="sapUiTinyMarginBottom"/>

                                    <Text
                                        text="Track bonafide requests"
                                        width="100%"
                                        textAlign="Center"/>

                                </VBox>

                            </TileContent>

                        </GenericTile>

                    </grid:CSSGrid>

                   
                    <grid:CSSGrid
                        gridTemplateColumns="1fr 1fr"
                        gridGap="1rem"
                        class="sapUiMediumMarginTop">

                        
                        <f:Card>

                            <f:header>

                                <card:Header
                                    title="📌 Recent Activity"/>

                            </f:header>

                            <f:content>

                                <VBox
                                    class="sapUiMediumMargin"
                                    alignItems="Center"
                                    justifyContent="Center"
                                    style="min-height:180px;">

                                    <core:Icon
                                        src="sap-icon://activity-items"
                                        size="3rem"
                                        color="#0f0f0f"
                                        class="sapUiSmallMarginBottom"/>

                                    <Text
                                        text="No activity yet"
                                        class="sapUiSmallMarginTop"/>

                                </VBox>

                            </f:content>

                        </f:Card>

                        
                        <f:Card>

                            <f:header>

                                <card:Header
                                    title="📊 Leave Balance"/>

                            </f:header>

                            <f:content>

                                <VBox class="sapUiMediumMargin">

                                   
                                    <VBox class="sapUiSmallMarginBottom">

                                        <HBox justifyContent="SpaceBetween">

                                            <Text text="Medical Leave"/>

                                            <Text
                                                text="10 / 15 days"
                                                design="Bold"/>

                                        </HBox>

                                        <ProgressIndicator
                                            percentValue="67"
                                            showValue="false"
                                            height="6px"
                                            state="Success"
                                            class="sapUiTinyMarginTop"/>

                                    </VBox>

                                    
                                    <VBox class="sapUiSmallMarginBottom">

                                        <HBox justifyContent="SpaceBetween">

                                            <Text text="Casual Leave"/>

                                            <Text
                                                text="5 / 10 days"
                                                design="Bold"/>

                                        </HBox>

                                        <ProgressIndicator
                                            percentValue="50"
                                            showValue="false"
                                            height="6px"
                                            state="Warning"
                                            class="sapUiTinyMarginTop"/>

                                    </VBox>

                                   
                                    <VBox class="sapUiSmallMarginBottom">

                                        <HBox justifyContent="SpaceBetween">

                                            <Text text="Emergency Leave"/>

                                            <Text
                                                text="3 / 5 days"
                                                design="Bold"/>

                                        </HBox>

                                        <ProgressIndicator
                                            percentValue="60"
                                            showValue="false"
                                            height="6px"
                                            state="Error"
                                            class="sapUiTinyMarginTop"/>

                                    </VBox>

                                    
                                    <VBox>

                                        <HBox justifyContent="SpaceBetween">

                                            <Text text="Personal Leave"/>

                                            <Text
                                                text="2 / 8 days"
                                                design="Bold"/>

                                        </HBox>

                                        <ProgressIndicator
                                            percentValue="25"
                                            showValue="false"
                                            height="6px"
                                            state="Information"
                                            class="sapUiTinyMarginTop"/>

                                    </VBox>

                                </VBox>

                            </f:content>

                        </f:Card>

                    </grid:CSSGrid>

                    <VBox height="2rem"/>

                </VBox>

            </ScrollContainer>

        </content>

    </Page>

</mvc:View>