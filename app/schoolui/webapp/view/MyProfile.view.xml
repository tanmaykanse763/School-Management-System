<mvc:View
    controllerName="schoolui.controller.MyProfile"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page title="My Profile">

        <content>

            <VBox
                width="85%"
                class="sapUiLargeMargin sapUiContentPadding">

                <!-- PROFILE HEADER -->
                <Panel
                    width="100%"
                    class="sapUiContentPadding sapUiLargeMarginBottom"
                    backgroundDesign="Solid">

                    <HBox
                        justifyContent="SpaceBetween"
                        alignItems="Center"
                        width="100%">

                        <!-- Left Profile Section -->
                        <HBox alignItems="Center">

                            <Avatar
                                displaySize="XL"
                                initials="PR"
                                backgroundColor="Accent6"
                                class="sapUiLargeMarginEnd"/>

                            <VBox>
                                <Title text="{student>/studentName}"/>
                                <Text text="{student>/studentEmail}"/>

                                <HBox class="sapUiSmallMarginTop">

                                    <ObjectStatus
                                        text="Student"
                                        state="Information"
                                        class="sapUiTinyMarginEnd"/>

                                    <ObjectStatus
                                        text="Active"
                                        state="Success"
                                        class="sapUiTinyMarginEnd"/>

                                </HBox>
                            </VBox>

                        </HBox>

                    </HBox>
                </Panel>

                
                <Panel
                    headerText="Personal Information"
                    width="100%"
                    class="sapUiContentPadding"
                    backgroundDesign="Solid">

                    <VBox class="sapUiMediumMargin">

                        <!-- Email -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://email"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Email"/>
                            </HBox>

                            <Text text="{student>/studentEmail}"/>
                        </HBox>

                        <!-- Phone -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://phone"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Phone"/>
                            </HBox>

                            <Text text="{student>/phone}"/>
                        </HBox>

                        <!-- Date of Birth -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://calendar"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Date of Birth"/>
                            </HBox>

                            <Text text="{student>/dob}"/>
                        </HBox>

                        <!-- Address -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://building"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Address"/>
                            </HBox>

                            <Text text="{student>/address}"/>
                        </HBox>

                        <!-- Department -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://education"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Department"/>
                            </HBox>

                            <Text text="{student>/department}"/>
                        </HBox>

                        <!-- Guardian Name -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://employee"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Guardian Name"/>
                            </HBox>

                            <Text text="{student>/guardianName}"/>
                        </HBox>

                        <!-- Guardian Number -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%">

                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://call"
                                    class="sapUiSmallMarginEnd"/>
                                <Text text="Guardian Number"/>
                            </HBox>

                            <Text text="{student>/guardianNumber}"/>
                        </HBox>

                    </VBox>

                </Panel>

            </VBox>

        </content>

    </Page>

</mvc:View>