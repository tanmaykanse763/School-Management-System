<mvc:View
    controllerName="schoolui.controller.MyProfile"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
>
    <Page title="My Profile">
        <content>
            <VBox
                width="85%"
                class="sapUiLargeMargin sapUiContentPadding"
            >
                <Panel
                    width="100%"
                    class="sapUiContentPadding sapUiLargeMarginBottom"
                    backgroundDesign="Solid"
                >
                    <HBox
                        justifyContent="SpaceBetween"
                        alignItems="Center"
                        width="100%"
                    >
                        <HBox alignItems="Center">
                            <Avatar
                                displaySize="XL"
                                initials=""
                                backgroundColor="Accent6"
                                class="sapUiLargeMarginEnd"
                            />

                            <VBox>
                                <Title text="{name}" />

                                <Text text="{email}" />

                                <HBox class="sapUiSmallMarginTop">
                                    <ObjectStatus
                                        text="{department}"
                                        state="Information"
                                        class="sapUiTinyMarginEnd"
                                    />

                                    <ObjectStatus
                                        text="Active"
                                        state="Success"
                                        class="sapUiTinyMarginEnd"
                                    />
                                </HBox>
                            </VBox>
                        </HBox>
                    </HBox>
                </Panel>

                <Panel
                    headerText="Personal Information"
                    width="100%"
                    class="sapUiContentPadding"
                    backgroundDesign="Solid"
                >
                    <VBox class="sapUiMediumMargin">
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://email"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Email" />
                            </HBox>

                            <Text text="{email}" />
                        </HBox>

                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://phone"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Phone" />
                            </HBox>

                            <Text text="{mobileNumber}" />
                        </HBox>

                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://calendar"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Date of Birth" />
                            </HBox>

                            <Text text="{dateOfBirth}" />
                        </HBox>

                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://home"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Address" />
                            </HBox>

                            <Text text="{address}" />
                        </HBox>

                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://education"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Department" />
                            </HBox>

                            <Text text="{department}" />
                        </HBox>

                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://employee"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Guardian Name" />
                            </HBox>

                            <Text text="{guardianName}" />
                        </HBox>

                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiSmallMarginBottom"
                            width="100%"
                        >
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="sap-icon://call"
                                    class="sapUiSmallMarginEnd"
                                />

                                <Text text="Guardian Number" />
                            </HBox>

                            <Text text="{guardianNumber}" />
                        </HBox>
                    </VBox>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
